# ── Apple Music ───────────────────────────────────────────────────────────────
# From https://developer.apple.com/account → Certificates, Identifiers & Profiles → Keys
APPLE_TEAM_ID=XXXXXXXXXX           # 10-char string, top-right of portal
APPLE_KEY_ID=XXXXXXXXXX            # shown when you create/view the key
APPLE_PRIVATE_KEY_PATH=./AuthKey_XXXXXXXXXX.p8   # path to downloaded .p8 file

# Run `npm run generate-token` → paste output here. Valid 180 days.
VITE_APPLE_DEVELOPER_TOKEN=

# ── PartyKit ───────────────────────────────────────────────────────────────────
# Only needed for production. For local dev, partykit runs on localhost:1999 automatically.
# After running `npx partykit deploy`, your host will be:
#   apple-music-party-radio.<your-github-username>.partykit.dev
VITE_PARTYKIT_HOST=
